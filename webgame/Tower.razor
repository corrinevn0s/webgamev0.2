@* Tower.razor *@

<g transform="translate(@(Tower.Position.X), @(Tower.Position.Y))">
    @* Основание башни *@
    <rect x="-20"
          y="-20"
          width="40"
          height="40"
          fill="@Tower.ColorHtml"
          stroke="black"
          stroke-width="2"
          rx="5" ry="5" />

    @* Символ типа башни *@
    <text x="-8"
          y="5"
          fill="white"
          font-size="20"
          font-weight="bold">
        @GetTowerSymbol()
    </text>

    @* Радиус поражения (отображается при наведении) *@
    @if (ShowRange)
    {
        <circle r="@Tower.Range"
                fill="none"
                stroke="gray"
                stroke-width="1"
                stroke-dasharray="5,5" />
    }
</g>

@code {
    [Parameter]
    public Tower Tower { get; set; }

    [Parameter]
    public bool ShowRange { get; set; }

    private string GetTowerSymbol()
    {
        return Tower.Type switch
        {
            TowerType.Archer => "🏹",
            TowerType.IceMage => "❄️",
            TowerType.FireMage => "🔥",
            TowerType.Witch => "🧙",
            _ => "🗼"
        };
    }
}